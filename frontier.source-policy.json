{
  "sourcePolicy": {
    "enabled": true,
    "preset": "strict-app",
    "enforcement": "error",
    "failOnViolation": true,
    "maxFrontierComponentsPerFile": 1,
    "maxLinesPerFile": 320,
    "maxCharsPerFile": 24000,
    "localImportExtensions": "source",
    "allowedLocalImportExtensions": [
      ".js",
      ".mjs",
      ".cjs",
      ".json",
      ".node",
      ".ts",
      ".tsx",
      ".jsx"
    ],
    "sourceExtensions": [
      ".js",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".jsx"
    ],
    "excludedSegments": [
      "node_modules",
      "dist",
      "build",
      "coverage",
      "results",
      "reports",
      "agent-runs",
      "agent-worktrees",
      ".cache",
      ".next",
      ".turbo",
      "out"
    ],
    "allowedOversizedFiles": {
      "test/smoke/js-ts-real-repo-corpus-metrics-assertions.mjs": {
        "maxChars": 30000,
        "reason": "Dense real-repo corpus assertion matrix covering checkout, license, command, live-project, and cache-policy evidence."
      }
    }
  }
}
